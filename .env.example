DATABASE_URL=postgresql://root:root@localhost:5444/aicard
AUTH_SECRET=
# Gemini key pool — round-robin fallback (each key tried once per request).
# Use GEMINI_API_KEY_<count> with any positive integer (_1, _2, … _10, etc.).
# Empty values are skipped. Duplicate key strings are deduplicated.
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
